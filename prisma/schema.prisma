generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id          String      @id @default(cuid())
  clerkId     String      @unique
  name        String
  email       String      @unique
  role        Role        @default(EMPLOYEE)
  createdAt   DateTime    @default(now())
  timeEntries TimeEntry[]
}

model Task {
  id              String      @id @default(cuid())
  clientJobNum    String?
  poLine          String      @unique
  poNumber        String?
  name            String
  description     String?
  client          String?
  approver        String?
  type            String?
  timesheetSubmit String?
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now())
  timeEntries     TimeEntry[]
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  taskId          String?
  taskName        String
  weekEnding      DateTime?
  payPeriodEnding DateTime?
  workDate        DateTime?
  totalHours      Decimal   @db.Decimal(10, 4)
  workDescription String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Speeds up the dominant read patterns: list-ordering by workDate, the
  // date-range filter, week/pay-period grouping, and per-user dashboards.
  @@index([workDate])
  @@index([weekEnding])
  @@index([payPeriodEnding])
  @@index([userId, workDate])
}

// Singleton app configuration — always exactly one row (id = "singleton").
model AppConfig {
  id               String   @id @default("singleton")
  payPeriodAnchor  DateTime
  payPeriodWeeks   Int      @default(2)
  updatedAt        DateTime @updatedAt
}
